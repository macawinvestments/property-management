# Local dev: copy to .env and fill in.
# Railway provides DATABASE_URL automatically in production.
DATABASE_URL=postgresql://user:password@localhost:5432/property_management
PORT=8080

# The shared app password (gate for the whole app).
APP_PASSWORD=otimamacaw2025@

# Allowed frontend origin for CORS (the Vercel URL in production).
ALLOWED_ORIGIN=*
